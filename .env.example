# Copy to .env and fill in from Supabase -> Project Settings -> API.
# Only the ANON key belongs here: anything VITE_-prefixed is compiled into the
# JS bundle and is readable by anyone who opens the site. The anon key is
# designed for that (RLS is what protects the data).
#
# NEVER put the service_role key in this file.
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
